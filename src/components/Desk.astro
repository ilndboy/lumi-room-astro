---
import type { DeskEntryRendered } from '../data/desk';

interface Props {
  entries: DeskEntryRendered[];
  voice: string;
}

const { entries, voice } = Astro.props;
---

<section class="desk-section" id="the-desk">

  <!-- Thin amber rule — threshold from sky to room -->
  <div class="threshold-rule" aria-hidden="true"></div>

  <div class="desk-content">

    <h2 class="section-heading">the desk</h2>

    <div class="entries">
      {entries.map((entry) => (
        <div class="entry">
          <h3 class="entry-title">{entry.title}</h3>
          <span class="entry-timestamp">last touched: {entry.lastTouchedRelative}</span>
          <p class="entry-state">{entry.state}</p>
        </div>
      ))}
    </div>

    <p class="voice-paragraph">{voice}</p>

  </div>

</section>

<style>
  /* ─── The Desk Section ─── */
  .desk-section {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem 4.5rem;
    background: var(--cedar-dark);
    color: var(--cream);
    overflow: hidden;
  }

  /* ─── Threshold Rule ─── */
  .threshold-rule {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--amber-dim) 20%,
      var(--amber) 50%,
      var(--amber-dim) 80%,
      transparent
    );
    opacity: 0.4;
  }

  /* ─── Content wrapper ─── */
  .desk-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 42rem;
    width: 100%;
  }

  /* ─── Section Heading ─── */
  .section-heading {
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 400;
    font-style: italic;
    color: var(--cream);
    letter-spacing: 0.02em;
    margin-bottom: 3.5rem;
    text-align: center;
    line-height: 1.2;
    opacity: 0.95;
  }

  /* ─── Entries List ─── */
  .entries {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2.75rem;
    margin-bottom: 3.5rem;
  }

  /* ─── Single Entry ─── */
  .entry {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .entry-title {
    font-family: var(--serif);
    font-size: clamp(1.0625rem, 2vw, 1.1875rem);
    font-weight: 500;
    font-style: normal;
    color: var(--cream);
    line-height: 1.4;
    opacity: 0.95;
  }

  .entry-timestamp {
    font-family: var(--sans);
    font-size: 0.6875rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: lowercase;
    color: var(--glass-dim);
    line-height: 1.6;
  }

  .entry-state {
    font-family: var(--sans);
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--glass);
    line-height: 1.65;
    max-width: 34rem;
  }

  /* ─── Voice Paragraph ─── */
  .voice-paragraph {
    font-family: var(--serif);
    font-size: clamp(1rem, 2.2vw, 1.1875rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.75;
    color: var(--cream);
    max-width: 38rem;
    text-align: center;
    opacity: 0.88;
  }

  /* ─── Responsive ─── */
  @media (max-width: 600px) {
    .desk-section {
      padding: 3rem 1.25rem 3.5rem;
    }
    .entries {
      gap: 2.25rem;
    }
    .voice-paragraph {
      max-width: 100%;
    }
    .entry-state {
      max-width: 100%;
    }
  }
</style>