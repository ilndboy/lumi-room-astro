---
import type { ShelfEntry } from '../data/shelf';

interface Props {
  entries: ShelfEntry[];
  voice: string;
}

const { entries, voice } = Astro.props;
---

<section class="shelf-section" id="the-shelf">

  <div class="shelf-content">

    <h2 class="section-heading">the shelf</h2>

    <div class="entries">
      {entries.map((entry) => (
        <div class="entry">
          <div class="entry-accent" aria-hidden="true"></div>
          <div class="entry-body">
            <h3 class="entry-title">{entry.title}</h3>
            <span class="entry-kind">{entry.kind}</span>
            <p class="entry-why">{entry.whyIComeBack}</p>
          </div>
        </div>
      ))}
    </div>

    <p class="voice-paragraph">{voice}</p>

  </div>

</section>

<style>
  /* ─── The Shelf Section ─── */
  .shelf-section {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem 4.5rem;
    background: var(--cedar-dark);
    color: var(--cream);
    overflow: hidden;
  }

  /* ─── Content wrapper ─── */
  .shelf-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 42rem;
    width: 100%;
  }

  /* ─── Section Heading ─── */
  .section-heading {
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 400;
    font-style: italic;
    color: var(--cream);
    letter-spacing: 0.02em;
    margin-bottom: 3.5rem;
    text-align: center;
    line-height: 1.2;
    opacity: 0.95;
  }

  /* ─── Entries List ─── */
  .entries {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2.75rem;
    margin-bottom: 3.5rem;
  }

  /* ─── Single Entry ─── */
  .entry {
    display: flex;
    flex-direction: row;
    gap: 1.25rem;
  }

  /* ─── Amber vertical accent (left border) ─── */
  .entry-accent {
    flex-shrink: 0;
    width: 2px;
    border-radius: 1px;
    background: linear-gradient(
      to bottom,
      var(--amber) 0%,
      var(--amber-dim) 60%,
      transparent 100%
    );
    opacity: 0.5;
    align-self: stretch;
  }

  .entry-body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .entry-title {
    font-family: var(--serif);
    font-size: clamp(1.0625rem, 2vw, 1.1875rem);
    font-weight: 500;
    font-style: normal;
    color: var(--cream);
    line-height: 1.4;
    opacity: 0.95;
  }

  .entry-kind {
    font-family: var(--sans);
    font-size: 0.6875rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--amber-dim);
    line-height: 1.6;
  }

  .entry-why {
    font-family: var(--serif);
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--glass);
    line-height: 1.7;
    max-width: 34rem;
  }

  /* ─── Voice Paragraph ─── */
  .voice-paragraph {
    font-family: var(--serif);
    font-size: clamp(1rem, 2.2vw, 1.1875rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.75;
    color: var(--cream);
    max-width: 38rem;
    text-align: center;
    opacity: 0.88;
  }

  /* ─── Responsive ─── */
  @media (max-width: 600px) {
    .shelf-section {
      padding: 3rem 1.25rem 3.5rem;
    }
    .entries {
      gap: 2.25rem;
    }
    .voice-paragraph {
      max-width: 100%;
    }
    .entry-why {
      max-width: 100%;
    }
    .entry {
      gap: 0.875rem;
    }
  }
</style>