---
import type { TelescopeEntry } from '../data/telescope';

interface Props {
  entries: TelescopeEntry[];
  voice: string;
}

const { entries, voice } = Astro.props;
---

<section class="telescope-section" id="the-telescope">

  <!-- Thin cool rule — the eye turns outward again -->
  <div class="outward-rule" aria-hidden="true"></div>

  <div class="telescope-content">

    <h2 class="section-heading">the telescope</h2>

    <div class="entries">
      {entries.map((entry) => (
        <div class="entry">
          <h3 class="entry-title">{entry.title}</h3>
          <span class="entry-kind">{entry.kind}</span>
          <p class="entry-what">{entry.whatImWatching}</p>
        </div>
      ))}
    </div>

    <p class="voice-paragraph">{voice}</p>

  </div>

</section>

<style>
  /* ─── The Telescope Section ─── */
  .telescope-section {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem 4.5rem;
    background: var(--cedar-dark);
    color: var(--cream);
    overflow: hidden;
  }

  /* ─── Outward Rule — thin cool-color divider at the top ─── */
  /* The eye is turning outward again; a single cool accent signals that shift. */
  .outward-rule {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--glass-dim) 20%,
      var(--sky-pale) 50%,
      var(--glass-dim) 80%,
      transparent
    );
    opacity: 0.35;
  }

  /* ─── Content wrapper ─── */
  .telescope-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 42rem;
    width: 100%;
  }

  /* ─── Section Heading ─── */
  .section-heading {
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 400;
    font-style: italic;
    color: var(--cream);
    letter-spacing: 0.02em;
    margin-bottom: 3.5rem;
    text-align: center;
    line-height: 1.2;
    opacity: 0.95;
  }

  /* ─── Entries List ─── */
  .entries {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2.75rem;
    margin-bottom: 3.5rem;
  }

  /* ─── Single Entry ─── */
  .entry {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .entry-title {
    font-family: var(--serif);
    font-size: clamp(1.0625rem, 2vw, 1.1875rem);
    font-weight: 500;
    font-style: italic;
    color: var(--cream);
    line-height: 1.4;
    opacity: 0.95;
  }

  /* Cool-color kind labels — the one gesture that signals "looking outward" */
  .entry-kind {
    font-family: var(--sans);
    font-size: 0.6875rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--glass-dim);
    line-height: 1.6;
  }

  .entry-what {
    font-family: var(--serif);
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--glass);
    line-height: 1.7;
    max-width: 34rem;
  }

  /* ─── Voice Paragraph ─── */
  .voice-paragraph {
    font-family: var(--serif);
    font-size: clamp(1rem, 2.2vw, 1.1875rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.75;
    color: var(--cream);
    max-width: 38rem;
    text-align: center;
    opacity: 0.88;
  }

  /* ─── Responsive ─── */
  @media (max-width: 600px) {
    .telescope-section {
      padding: 3rem 1.25rem 3.5rem;
    }
    .entries {
      gap: 2.25rem;
    }
    .voice-paragraph {
      max-width: 100%;
    }
    .entry-what {
      max-width: 100%;
    }
  }
</style>