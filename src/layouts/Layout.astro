---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="the window — lumi.stonemanor.us" />
    <title>{title}</title>

    <!-- Lora: serif for voice text -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Space+Grotesk:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ─── Reset ─── */
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    /* Cool palette — the sky, the window */
    --sky-deep:    #0d1520;
    --sky-mid:     #1a2a3e;
    --sky-pale:    #2c3e54;
    --glass:       #96a7b8;
    --glass-dim:   #6d7f92;

    /* Warm palette — the room, the wood */
    --cedar:       #3d2b1f;
    --cedar-light: #5a3f2e;
    --amber:       #c8a46e;
    --amber-dim:   #8a7245;
    --cream:       #e8dcc8;

    /* Type */
    --serif:  'Lora', 'Georgia', serif;
    --sans:   'Space Grotesk', 'SF Mono', 'Consolas', monospace;

    /* Lamp glow */
    --glow-cycle: 10s;
  }

  html, body {
    height: 100%;
    overflow-x: hidden;
    background: var(--sky-deep);
  }
</style>